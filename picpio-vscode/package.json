{
  "name": "picpio",
  "displayName": "PICPIO",
  "description": "PIC Microcontroller IDE — Build, Flash, Libraries, Serial Monitor",
  "version": "1.4.2",
  "publisher": "picpio",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Other"],
  "icon": "resources/logo.png",
  "repository": { "type": "git", "url": "https://github.com/picpio/picpio-vscode" },
  "activationEvents": [ "workspaceContains:picpio.ini" ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "picpio.home",          "title": "Home",                  "category": "PICPIO", "icon": "$(home)" },
      { "command": "picpio.build",         "title": "Build",                 "category": "PICPIO", "icon": "$(check)" },
      { "command": "picpio.upload",        "title": "Upload",                "category": "PICPIO", "icon": "$(arrow-right)" },
      { "command": "picpio.buildUpload",   "title": "Upload and Monitor",    "category": "PICPIO", "icon": "$(arrow-up)" },
      { "command": "picpio.clean",         "title": "Clean",                 "category": "PICPIO", "icon": "$(trash)" },
      { "command": "picpio.cleanBuild",    "title": "Clean Build",           "category": "PICPIO", "icon": "$(debug-restart)" },
      { "command": "picpio.cleanBuildUpload", "title": "Clean + Build + Upload", "category": "PICPIO", "icon": "$(run-all)" },
      { "command": "picpio.serialMonitor", "title": "Serial Port Monitor",   "category": "PICPIO", "icon": "$(plug)" },
      { "command": "picpio.openCli",       "title": "PICPIO Terminal",       "category": "PICPIO", "icon": "$(terminal)" },
      { "command": "picpio.libManager",    "title": "Library Manager",       "category": "PICPIO", "icon": "$(library)" },
      { "command": "picpio.newProject",    "title": "New Project",           "category": "PICPIO", "icon": "$(new-folder)" },
      { "command": "picpio.openProject",   "title": "Open Project",          "category": "PICPIO", "icon": "$(folder-opened)" },
      { "command": "picpio.libAdd",        "title": "Add Library",           "category": "PICPIO", "icon": "$(add)" },
      { "command": "picpio.libRemove",     "title": "Remove Library",        "category": "PICPIO", "icon": "$(remove)" },
      { "command": "picpio.refresh",       "title": "Refresh",               "category": "PICPIO", "icon": "$(refresh)" },
      { "command": "picpio.runTask",       "title": "Run Task",              "category": "PICPIO" },
      { "command": "picpio.taskMenu",      "title": "Run Task…",             "category": "PICPIO", "icon": "$(list-unordered)" },
      { "command": "picpio.insertSPI",     "title": "+ SPI",                 "category": "PICPIO", "icon": "$(circuit-board)" },
      { "command": "picpio.insertUSART",   "title": "+ USART",               "category": "PICPIO", "icon": "$(radio-tower)" },
      { "command": "picpio.insertI2C",     "title": "+ I2C",                 "category": "PICPIO", "icon": "$(sync)" },
      { "command": "picpio.insertPWM",     "title": "+ PWM",                 "category": "PICPIO", "icon": "$(zap)" },
      { "command": "picpio.simulate",      "title": "Simulate",              "category": "PICPIO", "icon": "$(pulse)" },
      { "command": "picpio.designer",      "title": "Display Designer",      "category": "PICPIO", "icon": "$(globe)" },
      { "command": "picpio.pidTune",       "title": "Auto PID Tuning",       "category": "PICPIO", "icon": "$(settings-gear)" },
      { "command": "picpio.checkUpdate",    "title": "Check for Updates",     "category": "PICPIO", "icon": "$(cloud-download)" }
    ],
    "viewsContainers": {
      "activitybar": [
        { "id": "picpio-sidebar", "title": "PICPIO", "icon": "resources/icons/pic.svg" }
      ]
    },
    "views": {
      "picpio-sidebar": [
        { "id": "picpioTasks",       "name": "Project Tasks" },
        { "id": "picpioQuickAccess", "name": "Quick Access" },
        { "id": "picpioProject",     "name": "Project Info" },
        { "id": "picpioLibraries",   "name": "Libraries" }
      ]
    },
    "menus": {
      "editor/title/run": [
        { "command": "picpio.build",         "when": "picpio.isActive", "group": "picpio@1" },
        { "command": "picpio.upload",        "when": "picpio.isActive", "group": "picpio@2" },
        { "command": "picpio.clean",         "when": "picpio.isActive", "group": "picpio@3" },
        { "command": "picpio.cleanBuild",    "when": "picpio.isActive", "group": "picpio@4" },
        { "command": "picpio.cleanBuildUpload", "when": "picpio.isActive", "group": "picpio@5" },
        { "command": "picpio.serialMonitor", "when": "picpio.isActive", "group": "picpio@6" },
        { "command": "picpio.insertSPI",     "when": "picpio.isActive && picpio.isPicpio", "group": "picpio@7" },
        { "command": "picpio.insertUSART",   "when": "picpio.isActive && picpio.isPicpio", "group": "picpio@8" },
        { "command": "picpio.insertI2C",     "when": "picpio.isActive && picpio.isPicpio", "group": "picpio@9" },
        { "command": "picpio.insertPWM",     "when": "picpio.isActive && picpio.isPicpio", "group": "picpio@10" },
        { "command": "picpio.simulate",      "when": "picpio.isActive && picpio.isPicpio", "group": "picpio@11" },
        { "command": "picpio.designer",      "when": "picpio.isActive && picpio.isPicpio", "group": "picpio@13" },
        { "command": "picpio.pidTune",       "when": "picpio.isActive && picpio.isPicpio", "group": "picpio@12" }
      ],
      "view/title": [
        { "command": "picpio.refresh", "when": "view == picpioTasks",    "group": "navigation" },
        { "command": "picpio.refresh", "when": "view == picpioProject",  "group": "navigation" },
        { "command": "picpio.libAdd",  "when": "view == picpioLibraries","group": "navigation" }
      ],
      "view/item/context": [
        { "command": "picpio.libRemove", "when": "viewItem == installedLib", "group": "inline" }
      ],
      "commandPalette": [
        { "command": "picpio.insertSPI",   "when": "picpio.isActive && picpio.isPicpio" },
        { "command": "picpio.insertUSART", "when": "picpio.isActive && picpio.isPicpio" },
        { "command": "picpio.insertI2C",   "when": "picpio.isActive && picpio.isPicpio" },
        { "command": "picpio.insertPWM",   "when": "picpio.isActive && picpio.isPicpio" },
        { "command": "picpio.simulate",    "when": "picpio.isActive && picpio.isPicpio" },
        { "command": "picpio.designer",    "when": "picpio.isActive && picpio.isPicpio" },
        { "command": "picpio.pidTune",     "when": "picpio.isActive && picpio.isPicpio" }
      ]
    },
    "keybindings": [
      { "command": "picpio.build",         "key": "ctrl+alt+b" },
      { "command": "picpio.upload",        "key": "ctrl+alt+u" },
      { "command": "picpio.cleanBuild",    "key": "ctrl+alt+r" },
      { "command": "picpio.serialMonitor", "key": "ctrl+alt+s" },
      { "command": "picpio.pidTune",       "key": "ctrl+alt+t" }
    ],
    "configuration": {
      "title": "PICPIO",
      "properties": {
        "picpio.executablePath":  { "type": "string",  "default": "picpio",  "description": "Path to picpio.exe" },
        "picpio.serialPort":      { "type": "string",  "default": "COM3",    "description": "Default serial port" },
        "picpio.serialBaud":      { "type": "number",  "default": 115200,    "description": "Serial baud rate" }
      }
    },
    "problemMatchers": [
      {
        "name": "xc8",
        "owner": "picpio",
        "fileLocation": "absolute",
        "pattern": { "regexp": "^(.+):(\\d+):\\s+(warning|error|note):\\s+(.+)$", "file":1,"line":2,"severity":3,"message":4 }
      },
      {
        "name": "xc8-2",
        "owner": "picpio",
        "fileLocation": "absolute",
        "pattern": { "regexp": "^(.+):(\\d+):(\\d+):\\s+(warning|error):\\s+(.+)$", "file":1,"line":2,"column":3,"severity":4,"message":5 }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch":   "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node":   "^18.0.0",
    "typescript":    "^5.0.0",
    "@vscode/vsce":  "^2.0.0"
  }
}
